# ── AI Providers (at least one required) ──
# Cerebras (primary — strict JSON, 600+ tok/s, 1M tokens/day free)
# Get free key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Groq (secondary — fast LPU inference with Llama 4 Scout)
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini (tertiary fallback — Gemini 2.5 Flash-Lite)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Other Services ──
# Redis (caching) - OPTIONAL
REDIS_URL=redis://localhost:6379

# CORS - Allow your Vercel frontend domain
# CORS_ORIGIN=https://your-app.vercel.app
